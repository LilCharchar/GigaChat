{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "db:up": "docker compose --env-file .env -f docker-compose.yml up -d",
    "db:down": "docker compose --env-file .env -f docker-compose.yml down",
    "migrate": "node scripts/run-migrations.js",
    "dev": "npm run migrate && nodemon src/index.js",
    "start": "npm run migrate && node src/index.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
